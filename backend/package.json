{
  "name": "boxmeout-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc --noEmit",
    "build:prod": "tsc",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "precommit": "node scripts/verify-schema.js",
    "migrate": "drizzle-kit migrate",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create",
    "migrate:generate": "drizzle-kit generate:pg",
    "migrate:check": "node scripts/migration-check.js",
    "migrate:dry-run": "node scripts/migration-check.js --dry-run",
    "drizzle:check": "drizzle-kit check:pg",
    "drizzle:pull": "drizzle-kit introspect:pg",
    "drizzle:studio": "drizzle-kit studio",
    "schema:verify": "node scripts/verify-schema.js",
    "test": "jest --passWithNoTests",
    "test:integration": "jest --passWithNoTests --testPathPatterns=tests/integration"
  },
  "dependencies": {
    "@sentry/node": "8.55.0",
    "@types/bcrypt": "^6.0.0",
    "@types/nodemailer": "^8.0.0",
    "bcrypt": "^6.0.0",
    "drizzle-kit": "^0.20.18",
    "drizzle-orm": "^0.30.10",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.6",
    "otpauth": "^9.5.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.13.0",
    "ws": "^8.18.2",
    "yaml": "^2.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@stellar/stellar-sdk": "^15.0.1",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/pino-http": "^5.8.4",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/ws": "^8.5.14",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "node-pg-migrate": "^8.0.4",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
