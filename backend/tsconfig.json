{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/controllers",
    "src/middleware/email-verification.middleware.ts",
    "src/routes/disputes.routes.ts",
    "src/routes/users.routes.ts",
    "src/schemas/validation.schemas.ts"
  ]
}
