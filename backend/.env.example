# ── Stellar Network ───────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org

# ── Contract Addresses (set after deployment) ─────────────────
FACTORY_CONTRACT_ADDRESS=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4
TREASURY_ADDRESS=

# ── Oracle Keypair (keep secret — use a secrets manager in prod) ─
ORACLE_PRIVATE_KEY=SBAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4
ORACLE_PUBLIC_KEY=GAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4

# ── Admin ─────────────────────────────────────────────────────
ADMIN_JWT_SECRET=your-admin-jwt-secret-change-in-production
ADMIN_PUBLIC_KEY=GAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4
ADMIN_PRIVATE_KEY=SBAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://boxmeout:boxmeout@localhost:5432/boxmeout
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=your-jwt-secret-change-in-production
ORACLE_API_KEY=your-oracle-api-key
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Indexer ───────────────────────────────────────────────────
GENESIS_LEDGER=100000
POLL_INTERVAL_MS=5000

# ── External Boxing Data API ──────────────────────────────────
BOXING_API_URL=https://api.example-boxing-data.com/v1

# ── Sentry ────────────────────────────────────────────────────
SENTRY_DSN=

# ── Alerting ─────────────────────────────────────────────────
ALERT_WEBHOOK_URL=

# ── Swagger ──────────────────────────────────────────────────
ENABLE_SWAGGER=false

# ── Email ─────────────────────────────────────────────────────
# Provider: smtp | sendgrid
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@boxmeout.app
# Required when EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.xxxx
APP_NAME=BoxMeOut
APP_BASE_URL=http://localhost:3001
